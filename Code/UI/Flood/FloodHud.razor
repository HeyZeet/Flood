@using Sandbox
@using System
@using System.Collections.Generic
@using System.Linq

@inherits PanelComponent

<root>
	@if ( ShouldShowWinner )
	{
		<div class="flood-hud__winner">
			<div class="flood-hud__winner-copy">
				<div class="flood-hud__winner-label">Round Winner</div>
				<div class="flood-hud__winner-name">@WinnerNameText</div>
			</div>
		</div>
	}

	@if ( ShouldShowScoreboard )
	{
		<div class="@ScoreboardCssClass">
			<div class="flood-hud__scoreboard-header">
				<div>
					<div class="flood-hud__scoreboard-title">Scoreboard</div>
					<div class="flood-hud__scoreboard-subtitle">@ScoreboardSubtitleText</div>
				</div>
				<div class="flood-hud__scoreboard-count">@ScoreboardPlayerCountText</div>
			</div>

			<div class="flood-hud__scoreboard-table">
				<div class="flood-hud__scoreboard-row flood-hud__scoreboard-row--head">
					<span class="flood-hud__scoreboard-name">Player</span>
					<span>Status</span>
					<span>K</span>
					<span>D</span>
					<span>$</span>
				</div>

				@foreach ( var row in ScoreboardRows )
				{
					<div class="@row.CssClass">
						<span class="flood-hud__scoreboard-name">@row.Name</span>
						<span>@row.Status</span>
						<span>@row.Kills</span>
						<span>@row.Deaths</span>
						<span>@row.Resources</span>
					</div>
				}
			</div>
		</div>
	}

	@if ( ShouldShowRound )
	{
		<div class="flood-hud__round">
			<div class="flood-hud__phase">@RoundPhaseText</div>
			<div class="flood-hud__time">@RoundTimeText</div>
		</div>
	}

	@if ( ShouldShowBuild )
	{
		<div class="flood-hud__build">
			<div class="flood-hud__section-title">Build</div>
			<div class="flood-hud__row">
				<span>Tool</span>
				<strong>@BuildToolText</strong>
			</div>
			<div class="flood-hud__row">
				<span>Piece</span>
				<strong>@BuildPieceText</strong>
			</div>
			<div class="flood-hud__row">
				<span>Resources</span>
				<strong>@ResourceText</strong>
			</div>
			<div class="flood-hud__hint">@BuildHintText</div>
		</div>
	}

	@if ( ShouldShowBuildMenu )
	{
		<div class="flood-hud__build-menu">
			<div class="flood-hud__build-menu-header">
				<div>
					<div class="flood-hud__build-menu-title">Build Menu</div>
					<div class="flood-hud__build-menu-subtitle">@BuildMenuSubtitleText</div>
				</div>
				<div class="flood-hud__build-menu-resources">$@ResourceText</div>
			</div>

			<div class="flood-hud__build-menu-tabs">
				@foreach ( var group in BuildMenuGroups )
				{
					<div class="@group.TabCssClass" onclick=@( () => SelectBuildMenuMaterial( group.Material ) )>
						<span class="flood-hud__build-menu-swatch"></span>
						<span>@group.Name</span>
					</div>
				}
			</div>

			<div class="flood-hud__build-menu-grid">
				@foreach ( var entry in VisibleBuildMenuEntries )
				{
					<div class="@entry.CssClass" onclick=@( () => SelectBuildPiece( entry.Index ) )>
						<div class="flood-hud__build-piece-preview">
							@if ( !string.IsNullOrWhiteSpace( entry.ModelPath ) )
							{
								<BuildPieceModelPanel ModelPath="@entry.ModelPath" />
							}
						</div>
						<div class="flood-hud__build-piece-name">@entry.Name</div>
						<div class="flood-hud__build-piece-stats">
							<span>$@entry.Cost</span>
							<span>@entry.Health hp</span>
						</div>
					</div>
				}
			</div>
		</div>
	}

	@if ( ShouldShowShop )
	{
		<div class="flood-hud__shop">
			<div class="flood-hud__shop-header">
				<div>
					<div class="flood-hud__shop-title">Shop</div>
					<div class="flood-hud__shop-subtitle">@ShopSubtitleText</div>
				</div>
				<div class="flood-hud__shop-resources">$@ShopResourceText</div>
			</div>

			<div class="flood-hud__shop-tabs">
				@foreach ( var tab in ShopTabs )
				{
					<div class="@tab.CssClass" onclick=@( () => SelectShopType( tab.ItemType ) )>@tab.Name</div>
				}
			</div>

			<div class="flood-hud__shop-list">
				@foreach ( var item in VisibleShopItems )
				{
					<div class="@item.CssClass">
						<div class="flood-hud__shop-preview">
							@if ( !string.IsNullOrWhiteSpace( item.ModelPath ) )
							{
								<BuildPieceModelPanel ModelPath="@item.ModelPath" />
							}
						</div>
						<div class="flood-hud__shop-copy">
							<div class="flood-hud__shop-item-name">@item.Name</div>
							<div class="flood-hud__shop-item-description">@item.Description</div>
							<div class="flood-hud__shop-item-meta">
								<span>$@item.Cost</span>
								<span>@item.Status</span>
							</div>
						</div>
						<div class="flood-hud__shop-buy" onclick=@( () => PurchaseShopItem( item.Index ) )>@item.ButtonText</div>
					</div>
				}
			</div>
		</div>
	}

	@if ( ShouldShowCarryableSelector )
	{
		<div class="flood-hud__carryable-selector">
			@foreach ( var item in CarryableSelectorItems )
			{
				<div class="@item.CssClass">
					<span class="flood-hud__carryable-slot">@item.SlotText</span>
					<span class="flood-hud__carryable-name">@item.Name</span>
				</div>
			}
		</div>
	}

	@if ( ShouldShowAmmo )
	{
		<div class="flood-hud__ammo">
			<div class="flood-hud__weapon">@WeaponText</div>
			<div class="flood-hud__ammo-row">
				<span class="flood-hud__clip">@AmmoClipText</span>
				<span class="flood-hud__slash">/</span>
				<span class="flood-hud__reserve">@AmmoReserveText</span>
			</div>
			@if ( IsReloading )
			{
				<div class="flood-hud__reload">Reloading...</div>
			}
		</div>
	}

	@if ( ShouldShowDeath )
	{
		<div class="flood-hud__death">
			<div class="flood-hud__death-panel">
				<div class="flood-hud__death-title">@DeathTitleText</div>
				<div class="flood-hud__death-subtitle">Waiting for the next round...</div>
			</div>
		</div>
	}
</root>

@code
{
	[Property] public bool ShowRoundDuringWaiting { get; set; } = false;
	[Property] public bool ShowRoundDebugValues { get; set; } = false;
	[Property] public string ScoreboardInputAction { get; set; } = "Score";
	[Property] public float CarryableSelectorDisplaySeconds { get; set; } = 1.25f;

	private bool ShouldShowRound { get; set; }
	private bool ShouldShowBuild { get; set; }
	private bool ShouldShowAmmo { get; set; }
	private bool ShouldShowDeath { get; set; }
	private bool ShouldShowScoreboard { get; set; }
	private bool ShouldShowWinner { get; set; }
	private bool ShouldShowBuildMenu { get; set; }
	private bool ShouldShowShop { get; set; }
	private bool ShouldShowCarryableSelector { get; set; }
	private bool IsReloading { get; set; }

	private string RoundPhaseText { get; set; } = "Waiting";
	private string RoundTimeText { get; set; } = "--:--";
	private string WinnerNameText { get; set; } = "No Winner";
	private string ScoreboardSubtitleText { get; set; } = "Hold score to view";
	private string ScoreboardPlayerCountText { get; set; } = "0 Players";
	private string ScoreboardCssClass { get; set; } = "flood-hud__scoreboard";
	private string BuildToolText { get; set; } = "None";
	private string BuildPieceText { get; set; } = "None";
	private string ResourceText { get; set; } = "--";
	private string BuildHintText { get; set; } = "";
	private string BuildMenuSubtitleText { get; set; } = "Select a piece";
	private string ShopResourceText { get; set; } = "--";
	private string ShopSubtitleText { get; set; } = "Weapons";
	private string WeaponText { get; set; } = "";
	private string AmmoClipText { get; set; } = "0";
	private string AmmoReserveText { get; set; } = "";
	private string DeathTitleText { get; set; } = "You Died";

	private int HudBuildVersion { get; set; }
	private GamePhase LastDisplayedPhase { get; set; }
	private float DisplaySecondsRemaining { get; set; }
	private List<ScoreboardRow> ScoreboardRows { get; set; } = new();
	private List<BuildMenuGroup> BuildMenuGroups { get; set; } = new();
	private List<BuildMenuEntry> VisibleBuildMenuEntries { get; set; } = new();
	private List<ShopTab> ShopTabs { get; set; } = new();
	private List<ShopEntry> VisibleShopItems { get; set; } = new();
	private List<CarryableSelectorItem> CarryableSelectorItems { get; set; } = new();
	private string ScoreboardStateKey { get; set; } = "";
	private string BuildMenuStateKey { get; set; } = "";
	private string ShopStateKey { get; set; } = "";
	private string CarryableSelectorStateKey { get; set; } = "";
	private BuildPieceMaterial SelectedBuildMenuMaterial { get; set; } = BuildPieceMaterial.Wood;
	private ShopItemType SelectedShopType { get; set; } = ShopItemType.Weapon;
	private BoatBuilder CurrentBuildMenuBuilder { get; set; }
	private PlayerShopController CurrentShopController { get; set; }
	private bool WasBuildMenuShowing { get; set; }
	private bool WasShopShowing { get; set; }
	private int LastCarryableSelectorSlot { get; set; } = int.MinValue;
	private float CarryableSelectorTimeRemaining { get; set; }
	private static readonly BuildPieceMaterial[] BuildMenuMaterialOrder =
	{
		BuildPieceMaterial.Wood,
		BuildPieceMaterial.Metal,
		BuildPieceMaterial.Plastic,
		BuildPieceMaterial.Armor,
		BuildPieceMaterial.Foam
	};
	private static readonly ShopItemType[] ShopTypeOrder =
	{
		ShopItemType.Weapon,
		ShopItemType.Perk,
		ShopItemType.GameModifier
	};

	private sealed class ScoreboardRow
	{
		public string Name { get; init; }
		public string Status { get; init; }
		public int Kills { get; init; }
		public int Deaths { get; init; }
		public string Resources { get; init; }
		public string CssClass { get; init; }

		public string StateKey => $"{Name}|{Status}|{Kills}|{Deaths}|{Resources}|{CssClass}";
	}

	private sealed class BuildMenuGroup
	{
		public BuildPieceMaterial Material { get; init; }
		public string Name { get; init; }
		public string TabCssClass { get; init; }
		public string StateKey => $"{Material}|{Name}|{TabCssClass}";
	}

	private sealed class BuildMenuEntry
	{
		public int Index { get; init; }
		public string Name { get; init; }
		public string ModelPath { get; init; }
		public int Cost { get; init; }
		public int Health { get; init; }
		public string CssClass { get; init; }
		public string StateKey => $"{Index}|{Name}|{ModelPath}|{Cost}|{Health}|{CssClass}";
	}

	private sealed class ShopTab
	{
		public ShopItemType ItemType { get; init; }
		public string Name { get; init; }
		public string CssClass { get; init; }
		public string StateKey => $"{ItemType}|{Name}|{CssClass}";
	}

	private sealed class ShopEntry
	{
		public int Index { get; init; }
		public string Name { get; init; }
		public string Description { get; init; }
		public string ModelPath { get; init; }
		public int Cost { get; init; }
		public string Status { get; init; }
		public string ButtonText { get; init; }
		public string CssClass { get; init; }
		public string StateKey => $"{Index}|{Name}|{Description}|{ModelPath}|{Cost}|{Status}|{ButtonText}|{CssClass}";
	}

	private sealed class CarryableSelectorItem
	{
		public string SlotText { get; init; }
		public string Name { get; init; }
		public string CssClass { get; init; }
		public string StateKey => $"{SlotText}|{Name}|{CssClass}";
	}

	protected override void OnUpdate()
	{
		base.OnUpdate();

		var player = GetHudPlayer();
		var roundManager = FloodGameManager.Instance;

		UpdateRoundState( player, roundManager );
		UpdateScoreboardState( player, roundManager );
		UpdatePlayerState( player, roundManager );
	}

	private FloodPlayer GetHudPlayer()
	{
		var player = Components.Get<FloodPlayer>( FindMode.EverythingInAncestors );

		if ( player.IsValid() )
			return player;

		return FloodPlayer.Local;
	}

	private void UpdateRoundState( FloodPlayer player, FloodGameManager roundManager )
	{
		if ( !player.IsValid() && !roundManager.IsValid() )
		{
			SetRoundState( false, "No Round", "--:--" );
			return;
		}

		var phase = player.IsValid() ? player.SyncedRoundPhase : roundManager.CurrentPhase;
		var syncedSeconds = player.IsValid() ? player.SyncedRoundSecondsRemaining : roundManager.GetCurrentPhaseTimeRemaining();
		var duration = player.IsValid() && player.SyncedRoundDuration > 0f
			? player.SyncedRoundDuration
			: roundManager.IsValid() ? roundManager.GetCurrentPhaseDuration() : 0f;

		var shouldShow = ShowRoundDuringWaiting || phase != GamePhase.WaitingForPlayers;
		var displaySeconds = GetDisplaySecondsRemaining( phase, syncedSeconds, duration );
		var timeText = FormatTime( displaySeconds );

		if ( ShowRoundDebugValues )
			timeText = $"{timeText} | raw:{syncedSeconds:0.0} | src:{(player.IsValid() ? "player" : "manager")}";

		SetRoundState( shouldShow, GetPhaseText( phase ), timeText );
	}

	private void UpdateScoreboardState( FloodPlayer player, FloodGameManager roundManager )
	{
		var phase = player.IsValid() ? player.SyncedRoundPhase : roundManager.IsValid() ? roundManager.CurrentPhase : GamePhase.WaitingForPlayers;
		var showWinner = phase == GamePhase.RoundEnd;
		var showScoreboard = showWinner || IsScoreboardInputHeld();
		var winnerName = GetWinnerName( roundManager );
		var rows = BuildScoreboardRows();
		var subtitle = showWinner ? "Final round results" : "Live round results";
		var playerCountText = rows.Count == 1 ? "1 Player" : $"{rows.Count} Players";
		var scoreboardCssClass = showWinner
			? "flood-hud__scoreboard flood-hud__scoreboard--round-end"
			: "flood-hud__scoreboard";
		var stateKey = string.Join( ";", rows.Select( row => row.StateKey ) );

		if (
			ShouldShowWinner == showWinner &&
			ShouldShowScoreboard == showScoreboard &&
			WinnerNameText == winnerName &&
			ScoreboardSubtitleText == subtitle &&
			ScoreboardPlayerCountText == playerCountText &&
			ScoreboardCssClass == scoreboardCssClass &&
			ScoreboardStateKey == stateKey
		)
		{
			return;
		}

		ShouldShowWinner = showWinner;
		ShouldShowScoreboard = showScoreboard;
		WinnerNameText = winnerName;
		ScoreboardSubtitleText = subtitle;
		ScoreboardPlayerCountText = playerCountText;
		ScoreboardCssClass = scoreboardCssClass;
		ScoreboardRows = rows;
		ScoreboardStateKey = stateKey;
		HudBuildVersion++;
	}

	private bool IsScoreboardInputHeld()
	{
		if ( string.IsNullOrWhiteSpace( ScoreboardInputAction ) )
			return false;

		return Input.Down( ScoreboardInputAction );
	}

	private string GetWinnerName( FloodGameManager roundManager )
	{
		if ( roundManager.IsValid() && !string.IsNullOrWhiteSpace( roundManager.RoundWinnerName ) )
			return roundManager.RoundWinnerName;

		return "No Winner";
	}

	private List<ScoreboardRow> BuildScoreboardRows()
	{
		return FloodPlayer.All
			.Where( player => player.IsValid() )
			.OrderByDescending( player => player.Kills )
			.ThenBy( player => player.Deaths )
			.ThenBy( player => player.PlayerName )
			.Select( BuildScoreboardRow )
			.ToList();
	}

	private ScoreboardRow BuildScoreboardRow( FloodPlayer player )
	{
		var isLocal = player == FloodPlayer.Local;
		var status = player.IsEliminated ? "Out" : player.IsDead ? "Dead" : "Alive";
		var resources = player.BuildResources.IsValid() ? player.BuildResources.Resources.ToString() : "--";
		var cssClass = "flood-hud__scoreboard-row";

		if ( isLocal )
			cssClass += " is-local";

		if ( player.IsEliminated || player.IsDead )
			cssClass += " is-dead";

		return new ScoreboardRow
		{
			Name = string.IsNullOrWhiteSpace( player.PlayerName ) ? player.GameObject.Name : player.PlayerName,
			Status = status,
			Kills = player.Kills,
			Deaths = player.Deaths,
			Resources = resources,
			CssClass = cssClass
		};
	}

	private void UpdatePlayerState( FloodPlayer player, FloodGameManager roundManager )
	{
		if ( !player.IsValid() )
		{
			SetBuildState( false, "None", "None", "--", "" );
			SetCarryableSelectorState( false, null );
			SetAmmoState( false, "", "0", "", false );
			SetDeathState( false, "You Died" );
			return;
		}

		SetDeathState( player.IsDead, player.IsEliminated ? "Eliminated" : "You Died" );

		if ( player.IsDead )
		{
			SetBuildState( false, "None", "None", "--", "" );
			SetBuildMenuState( false, null );
			SetShopState( false, null, "--" );
			SetCarryableSelectorState( false, null );
			SetAmmoState( false, "", "0", "", false );
			return;
		}

		var inventory = player.Inventory;
		var activeCarryable = inventory.IsValid() ? inventory.ActiveCarryable : null;
		var resources = player.BuildResources;
		var resourceText = resources.IsValid() ? resources.Resources.ToString() : "--";

		UpdateBuildState( player, roundManager, activeCarryable, resourceText );
		SetShopState( PlayerShopController.Local.IsValid() && PlayerShopController.Local.IsShopOpen, PlayerShopController.Local, resourceText );
		UpdateCarryableSelectorState( inventory );
		UpdateAmmoState( activeCarryable );
	}

	private void UpdateCarryableSelectorState( PlayerInventory inventory )
	{
		if ( !inventory.IsValid() || ShouldShowBuildMenu || ShouldShowShop )
		{
			SetCarryableSelectorState( false, null );
			LastCarryableSelectorSlot = inventory.IsValid() ? inventory.ActiveSlot : int.MinValue;
			return;
		}

		var activeSlot = inventory.ActiveSlot;
		var hasActiveSlotChanged = LastCarryableSelectorSlot != int.MinValue && LastCarryableSelectorSlot != activeSlot;
		var shouldPulseSelector = hasActiveSlotChanged || WasCarryableSelectionInputPressed();

		LastCarryableSelectorSlot = activeSlot;

		if ( shouldPulseSelector )
			CarryableSelectorTimeRemaining = CarryableSelectorDisplaySeconds.Clamp( 0.1f, 10f );

		if ( CarryableSelectorTimeRemaining > 0f )
			CarryableSelectorTimeRemaining -= Time.Delta;

		SetCarryableSelectorState( CarryableSelectorTimeRemaining > 0f, inventory );
	}

	private bool WasCarryableSelectionInputPressed()
	{
		if ( Input.MouseWheel.y != 0 )
			return true;

		return Input.Pressed( "Slot1" )
			|| Input.Pressed( "Slot2" )
			|| Input.Pressed( "Slot3" )
			|| Input.Pressed( "Slot4" );
	}

	private void UpdateBuildState( FloodPlayer player, FloodGameManager roundManager, BaseCarryable activeCarryable, string resourceText )
	{
		var isBuildPhase = player.IsValid()
			? player.IsRoundBuildPhase
			: !roundManager.IsValid() || roundManager.IsBuildPhase();

		if ( !isBuildPhase )
		{
			SetBuildState( false, "None", "None", "--", "" );
			SetBuildMenuState( false, null );
			return;
		}

		if ( !activeCarryable.IsValid() )
		{
			SetBuildState( false, "None", "None", "--", "" );
			SetBuildMenuState( false, null );
			return;
		}

		if ( activeCarryable is BoatBuilder boatBuilder )
		{
			var buildMenuBuilder = BoatBuilder.LocalBuildMenuBuilder.IsValid()
				? BoatBuilder.LocalBuildMenuBuilder
				: boatBuilder;

			SetBuildState(
				true,
				boatBuilder.DisplayName,
				boatBuilder.SelectedPiece?.DisplayName ?? "None",
				resourceText,
				"LMB: Place   RMB: Next Piece   Q: Build Menu   R: Rotate"
			);
			SetBuildMenuState( BoatBuilder.IsLocalBuildMenuOpen, buildMenuBuilder );
			return;
		}

		var weldTool = activeCarryable.Components.Get<WeldToolWeapon>( FindMode.EverythingInSelfAndDescendants );

		if ( weldTool.IsValid() )
		{
			SetBuildState( true, weldTool.DisplayName, weldTool.FirstWeldTargetName, resourceText, "LMB: Select   R: Weld Selected   RMB: Unweld" );
			SetBuildMenuState( false, null );
			return;
		}

		SetBuildState( false, "None", "None", "--", "" );
		SetBuildMenuState( false, null );
	}

	private void UpdateAmmoState( BaseCarryable activeCarryable )
	{
		if ( !activeCarryable.IsValid() )
		{
			SetAmmoState( false, "", "0", "", false );
			return;
		}

		var gun = activeCarryable.Components.Get<BaseGunWeapon>( FindMode.EverythingInSelfAndDescendants );

		if ( !gun.IsValid() )
		{
			SetAmmoState( false, "", "0", "", false );
			return;
		}

		SetAmmoState(
			true,
			gun.DisplayName,
			gun.AmmoInClip.ToString(),
			GetReserveText( gun ),
			gun.IsReloading
		);
	}

	private string GetReserveText( BaseGunWeapon gun )
	{
		if ( gun.InfiniteAmmo )
			return "INF";

		if ( !gun.HasReserveAmmo )
			return "--";

		return gun.ReserveAmmo.ToString();
	}

	private float GetDisplaySecondsRemaining( GamePhase phase, float syncedSeconds, float phaseDuration )
	{
		syncedSeconds = syncedSeconds.Clamp( 0f, float.MaxValue );

		if ( LastDisplayedPhase != phase )
		{
			LastDisplayedPhase = phase;
			DisplaySecondsRemaining = syncedSeconds > 0f ? syncedSeconds : phaseDuration;
			return DisplaySecondsRemaining;
		}

		if ( syncedSeconds > DisplaySecondsRemaining || MathF.Abs( syncedSeconds - DisplaySecondsRemaining ) > 1.25f )
		{
			DisplaySecondsRemaining = syncedSeconds;
			return DisplaySecondsRemaining;
		}

		DisplaySecondsRemaining -= Time.Delta;
		DisplaySecondsRemaining = DisplaySecondsRemaining.Clamp( 0f, float.MaxValue );

		return DisplaySecondsRemaining;
	}

	private string GetPhaseText( GamePhase phase )
	{
		return phase switch
		{
			GamePhase.WaitingForPlayers => "Waiting",
			GamePhase.BuildPhase => "Build Phase",
			GamePhase.FloodPhase => "Flood Phase",
			GamePhase.CombatPhase => "Combat Phase",
			GamePhase.RoundEnd => "Round End",
			_ => phase.ToString()
		};
	}

	private string FormatTime( float seconds )
	{
		seconds = seconds.Clamp( 0f, float.MaxValue );

		var totalSeconds = MathF.Ceiling( seconds );
		var minutes = (int)(totalSeconds / 60f);
		var remainingSeconds = (int)(totalSeconds % 60f);

		return $"{minutes:00}:{remainingSeconds:00}";
	}

	private void SetRoundState( bool shouldShow, string phaseText, string timeText )
	{
		if ( ShouldShowRound == shouldShow && RoundPhaseText == phaseText && RoundTimeText == timeText )
			return;

		ShouldShowRound = shouldShow;
		RoundPhaseText = phaseText;
		RoundTimeText = timeText;
		HudBuildVersion++;
	}

	private void SetBuildState( bool shouldShow, string toolText, string pieceText, string resourceText, string hintText )
	{
		if (
			ShouldShowBuild == shouldShow &&
			BuildToolText == toolText &&
			BuildPieceText == pieceText &&
			ResourceText == resourceText &&
			BuildHintText == hintText
		)
		{
			return;
		}

		ShouldShowBuild = shouldShow;
		BuildToolText = toolText;
		BuildPieceText = pieceText;
		ResourceText = resourceText;
		BuildHintText = hintText;
		HudBuildVersion++;
	}

	private void SetBuildMenuState( bool shouldShow, BoatBuilder boatBuilder )
	{
		CurrentBuildMenuBuilder = shouldShow && boatBuilder.IsValid() ? boatBuilder : null;

		if ( !shouldShow || !boatBuilder.IsValid() )
		{
			WasBuildMenuShowing = false;

			if ( ShouldShowBuildMenu )
			{
				ShouldShowBuildMenu = false;
				BuildMenuGroups.Clear();
				VisibleBuildMenuEntries.Clear();
				BuildMenuStateKey = "";
				HudBuildVersion++;
			}

			return;
		}

		if ( !WasBuildMenuShowing && boatBuilder.SelectedPiece is not null )
			SelectedBuildMenuMaterial = boatBuilder.SelectedPiece.Material;

		WasBuildMenuShowing = true;

		var groups = BuildMenuMaterialOrder
			.Where( material => boatBuilder.AvailablePieces.Any( piece => piece is not null && piece.Material == material ) )
			.Select( material => new BuildMenuGroup
			{
				Material = material,
				Name = GetMaterialName( material ),
				TabCssClass = material == SelectedBuildMenuMaterial
					? $"flood-hud__build-menu-tab is-active material-{material.ToString().ToLower()}"
					: $"flood-hud__build-menu-tab material-{material.ToString().ToLower()}"
			} )
			.ToList();

		if ( groups.Count > 0 && groups.All( group => group.Material != SelectedBuildMenuMaterial ) )
			SelectedBuildMenuMaterial = groups[0].Material;

		var entries = boatBuilder.AvailablePieces
			.Select( ( piece, index ) => CreateBuildMenuEntry( boatBuilder, piece, index ) )
			.Where( entry => entry is not null )
			.ToList();

		var subtitle = $"{GetMaterialName( SelectedBuildMenuMaterial )} pieces";
		var stateKey = string.Join( ";", groups.Select( group => group.StateKey ) )
			+ "|"
			+ string.Join( ";", entries.Select( entry => entry.StateKey ) )
			+ $"|{subtitle}|{boatBuilder.SelectedPieceIndex}";

		if (
			ShouldShowBuildMenu == shouldShow &&
			BuildMenuStateKey == stateKey
		)
		{
			return;
		}

		ShouldShowBuildMenu = shouldShow;
		BuildMenuGroups = groups;
		VisibleBuildMenuEntries = entries;
		BuildMenuSubtitleText = subtitle;
		BuildMenuStateKey = stateKey;
		HudBuildVersion++;
	}

	private void SetShopState( bool shouldShow, PlayerShopController shop, string resourceText )
	{
		CurrentShopController = shouldShow && shop.IsValid() ? shop : null;
		ShopResourceText = resourceText;

		if ( !shouldShow || !shop.IsValid() )
		{
			WasShopShowing = false;

			if ( ShouldShowShop )
			{
				ShouldShowShop = false;
				ShopTabs.Clear();
				VisibleShopItems.Clear();
				ShopStateKey = "";
				ShopResourceText = "--";
				HudBuildVersion++;
			}

			return;
		}

		if ( !WasShopShowing )
			SelectedShopType = ShopItemType.Weapon;

		WasShopShowing = true;

		var catalog = shop.Items;
		var tabs = ShopTypeOrder
			.Where( itemType => catalog.Any( item => item is not null && item.ItemType == itemType ) )
			.Select( itemType => new ShopTab
			{
				ItemType = itemType,
				Name = GetShopTypeName( itemType ),
				CssClass = itemType == SelectedShopType
					? $"flood-hud__shop-tab is-active type-{itemType.ToString().ToLower()}"
					: $"flood-hud__shop-tab type-{itemType.ToString().ToLower()}"
			} )
			.ToList();

		if ( tabs.Count > 0 && tabs.All( tab => tab.ItemType != SelectedShopType ) )
			SelectedShopType = tabs[0].ItemType;

		var entries = catalog
			.Select( ( item, index ) => CreateShopEntry( shop, item, index ) )
			.Where( entry => entry is not null )
			.ToList();

		var subtitle = $"{GetShopTypeName( SelectedShopType )}";
		var stateKey = string.Join( ";", tabs.Select( tab => tab.StateKey ) )
			+ "|"
			+ string.Join( ";", entries.Select( entry => entry.StateKey ) )
			+ $"|{subtitle}|{ShopResourceText}";

		if ( ShouldShowShop == shouldShow && ShopStateKey == stateKey )
			return;

		ShouldShowShop = shouldShow;
		ShopTabs = tabs;
		VisibleShopItems = entries;
		ShopSubtitleText = subtitle;
		ShopStateKey = stateKey;
		HudBuildVersion++;
	}

	private void SetCarryableSelectorState( bool shouldShow, PlayerInventory inventory )
	{
		if ( !shouldShow || !inventory.IsValid() )
		{
			if ( ShouldShowCarryableSelector )
			{
				ShouldShowCarryableSelector = false;
				CarryableSelectorItems.Clear();
				CarryableSelectorStateKey = "";
				HudBuildVersion++;
			}

			return;
		}

		var items = inventory.Carryables
			.Where( carryable => carryable.IsValid() )
			.OrderBy( carryable => carryable.InventorySlot )
			.Select( carryable => new CarryableSelectorItem
			{
				SlotText = GetCarryableSlotText( carryable.InventorySlot ),
				Name = carryable.DisplayName,
				CssClass = carryable.InventorySlot == inventory.ActiveSlot
					? "flood-hud__carryable-item is-active"
					: "flood-hud__carryable-item"
			} )
			.ToList();

		var stateKey = string.Join( ";", items.Select( item => item.StateKey ) );

		if ( ShouldShowCarryableSelector == shouldShow && CarryableSelectorStateKey == stateKey )
			return;

		ShouldShowCarryableSelector = shouldShow;
		CarryableSelectorItems = items;
		CarryableSelectorStateKey = stateKey;
		HudBuildVersion++;
	}

	private string GetCarryableSlotText( int slot )
	{
		if ( slot < 0 )
			return "-";

		return (slot + 1).ToString();
	}

	private ShopEntry CreateShopEntry( PlayerShopController shop, ShopItemData item, int index )
	{
		if ( item is null || item.ItemType != SelectedShopType )
			return null;

		var owned = shop.IsPurchasedOrOwned( item );
		var canAfford = shop.CanAfford( item );
		var available = !owned && canAfford;
		var model = item.PreviewModel.IsValid()
			? item.PreviewModel
			: item.WeaponPrefab.IsValid()
				? item.WeaponPrefab.Components.Get<ModelRenderer>( FindMode.EverythingInSelfAndDescendants )?.Model
				: null;

		return new ShopEntry
		{
			Index = index,
			Name = item.DisplayName,
			Description = string.IsNullOrWhiteSpace( item.Description ) ? GetDefaultShopDescription( item ) : item.Description,
			ModelPath = model.IsValid() ? model.ResourcePath : "",
			Cost = item.Cost,
			Status = owned ? "Owned" : canAfford ? "Available" : "Need more cash",
			ButtonText = owned ? "Owned" : "Buy",
			CssClass = available
				? "flood-hud__shop-item"
				: "flood-hud__shop-item is-disabled"
		};
	}

	private void SelectShopType( ShopItemType itemType )
	{
		SelectedShopType = itemType;
		ShopStateKey = "";
		HudBuildVersion++;
	}

	private void PurchaseShopItem( int index )
	{
		if ( !CurrentShopController.IsValid() )
			return;

		CurrentShopController.RequestPurchase( index );
	}

	private string GetShopTypeName( ShopItemType itemType )
	{
		return itemType switch
		{
			ShopItemType.Weapon => "Weapons",
			ShopItemType.Perk => "Perks",
			ShopItemType.GameModifier => "Modifiers",
			_ => itemType.ToString()
		};
	}

	private string GetDefaultShopDescription( ShopItemData item )
	{
		return item.ItemType switch
		{
			ShopItemType.Weapon => "Adds this weapon to your inventory.",
			ShopItemType.Perk => "Perk hook reserved for a future gameplay upgrade.",
			ShopItemType.GameModifier => "Modifier hook reserved for future round rules.",
			_ => ""
		};
	}

	private BuildMenuEntry CreateBuildMenuEntry( BoatBuilder boatBuilder, BuildPieceData piece, int index )
	{
		if ( piece is null || piece.Material != SelectedBuildMenuMaterial )
			return null;

		var isSelected = index == boatBuilder.SelectedPieceIndex;
		var canAfford = int.TryParse( ResourceText, out var resources ) && resources >= piece.Cost;
		var cssClass = isSelected
			? "flood-hud__build-piece-slot is-selected"
			: canAfford
				? "flood-hud__build-piece-slot"
				: "flood-hud__build-piece-slot cannot-afford";

		return new BuildMenuEntry
		{
			Index = index,
			Name = piece.DisplayName,
			ModelPath = piece.PropModel.IsValid() ? piece.PropModel.ResourcePath : "",
			Cost = piece.Cost,
			Health = (int)MathF.Round( piece.MaxHealth ),
			CssClass = cssClass
		};
	}

	private void SelectBuildMenuMaterial( BuildPieceMaterial material )
	{
		SelectedBuildMenuMaterial = material;
		BuildMenuStateKey = "";
		HudBuildVersion++;
	}

	private void SelectBuildPiece( int index )
	{
		if ( !CurrentBuildMenuBuilder.IsValid() )
			return;

		CurrentBuildMenuBuilder.SelectPieceFromBuildMenu( index );
	}

	private string GetMaterialName( BuildPieceMaterial material )
	{
		return material switch
		{
			BuildPieceMaterial.Wood => "Wood",
			BuildPieceMaterial.Metal => "Metal",
			BuildPieceMaterial.Plastic => "Plastic",
			BuildPieceMaterial.Armor => "Armor",
			BuildPieceMaterial.Foam => "Foam",
			_ => material.ToString()
		};
	}

	private void SetAmmoState( bool shouldShow, string weaponText, string clipText, string reserveText, bool isReloading )
	{
		if (
			ShouldShowAmmo == shouldShow &&
			WeaponText == weaponText &&
			AmmoClipText == clipText &&
			AmmoReserveText == reserveText &&
			IsReloading == isReloading
		)
		{
			return;
		}

		ShouldShowAmmo = shouldShow;
		WeaponText = weaponText;
		AmmoClipText = clipText;
		AmmoReserveText = reserveText;
		IsReloading = isReloading;
		HudBuildVersion++;
	}

	private void SetDeathState( bool shouldShow, string titleText )
	{
		if ( ShouldShowDeath == shouldShow && DeathTitleText == titleText )
			return;

		ShouldShowDeath = shouldShow;
		DeathTitleText = titleText;
		HudBuildVersion++;
	}

	protected override int BuildHash()
	{
		var hash = new HashCode();

		hash.Add( HudBuildVersion );
		hash.Add( ShouldShowRound );
		hash.Add( ShouldShowBuild );
		hash.Add( ShouldShowBuildMenu );
		hash.Add( ShouldShowShop );
		hash.Add( ShouldShowCarryableSelector );
		hash.Add( ShouldShowAmmo );
		hash.Add( ShouldShowDeath );
		hash.Add( ShouldShowScoreboard );
		hash.Add( ShouldShowWinner );
		hash.Add( IsReloading );
		hash.Add( RoundPhaseText );
		hash.Add( RoundTimeText );
		hash.Add( WinnerNameText );
		hash.Add( ScoreboardSubtitleText );
		hash.Add( ScoreboardPlayerCountText );
		hash.Add( ScoreboardCssClass );
		hash.Add( ScoreboardStateKey );
		hash.Add( BuildToolText );
		hash.Add( BuildPieceText );
		hash.Add( ResourceText );
		hash.Add( BuildHintText );
		hash.Add( BuildMenuStateKey );
		hash.Add( BuildMenuSubtitleText );
		hash.Add( ShopResourceText );
		hash.Add( ShopStateKey );
		hash.Add( ShopSubtitleText );
		hash.Add( CarryableSelectorStateKey );
		hash.Add( WeaponText );
		hash.Add( AmmoClipText );
		hash.Add( AmmoReserveText );
		hash.Add( DeathTitleText );
		hash.Add( ShowRoundDuringWaiting );
		hash.Add( ShowRoundDebugValues );
		hash.Add( ScoreboardInputAction );
		hash.Add( CarryableSelectorDisplaySeconds );

		return hash.ToHashCode();
	}
}
