@using Sandbox
@using System

@inherits PanelComponent

<root>
</root>

@code
{
	private bool ShouldShowHud { get; set; }
	private string WeaponName { get; set; } = "";
	private int AmmoInClip { get; set; }
	private string ReserveText { get; set; } = "";
	private bool IsReloading { get; set; }

	private int HudBuildVersion { get; set; }

	protected override void OnUpdate()
	{
		base.OnUpdate();
	}

	private void UpdateHudText()
	{
		var player = FloodPlayer.Local;

		if ( !player.IsValid() )
		{
			SetHudState( false, "", 0, "", false );
			return;
		}

		var inventory = player.Inventory;

		if ( !inventory.IsValid() )
		{
			SetHudState( false, "", 0, "", false );
			return;
		}

		var activeCarryable = inventory.ActiveCarryable;

		if ( !activeCarryable.IsValid() )
		{
			SetHudState( false, "", 0, "", false );
			return;
		}

		var gun = activeCarryable.Components.Get<BaseGunWeapon>( FindMode.EverythingInSelfAndDescendants );

		if ( !gun.IsValid() )
		{
			SetHudState( false, "", 0, "", false );
			return;
		}

		var reserveText = GetReserveText( gun );

		SetHudState(
			true,
			gun.DisplayName,
			gun.AmmoInClip,
			reserveText,
			gun.IsReloading
		);
	}

	private string GetReserveText( BaseGunWeapon gun )
	{
		if ( !gun.IsValid() )
			return "";

		if ( gun.InfiniteAmmo )
			return "INF";

		if ( !gun.HasReserveAmmo )
			return "--";

		return gun.ReserveAmmo.ToString();
	}

	private void SetHudState( bool shouldShow, string weaponName, int ammoInClip, string reserveText, bool isReloading )
	{
		if (
			ShouldShowHud == shouldShow &&
			WeaponName == weaponName &&
			AmmoInClip == ammoInClip &&
			ReserveText == reserveText &&
			IsReloading == isReloading
		)
		{
			return;
		}

		ShouldShowHud = shouldShow;
		WeaponName = weaponName;
		AmmoInClip = ammoInClip;
		ReserveText = reserveText;
		IsReloading = isReloading;

		HudBuildVersion++;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			HudBuildVersion,
			ShouldShowHud,
			WeaponName,
			AmmoInClip,
			ReserveText,
			IsReloading
		);
	}
}
