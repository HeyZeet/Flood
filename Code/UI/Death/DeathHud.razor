@using Sandbox
@using System

@inherits PanelComponent

<root>
</root>

@code
{
	[Property] public bool EnableDebugHint { get; set; } = true;

	private bool ShouldShow { get; set; }
	private string TitleText { get; set; } = "You Died";
	private int HudBuildVersion { get; set; }

	protected override void OnUpdate()
	{
		base.OnUpdate();
	}

	private void SetHudState( bool shouldShow, string titleText )
	{
		if ( ShouldShow == shouldShow && TitleText == titleText )
			return;

		ShouldShow = shouldShow;
		TitleText = titleText;
		HudBuildVersion++;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			HudBuildVersion,
			ShouldShow,
			TitleText,
			EnableDebugHint
		);
	}
}
