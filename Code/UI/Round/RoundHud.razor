@using Sandbox
@using System

@inherits PanelComponent

<root>
</root>

@code
{
	[Property] public bool ShowDuringWaiting { get; set; } = false;
	[Property] public bool ShowDebugValues { get; set; } = false;

	private bool ShouldShow { get; set; }
	private string PhaseText { get; set; } = "Waiting";
	private string TimeText { get; set; } = "--:--";

	private int HudBuildVersion { get; set; }
	private GamePhase LastDisplayedPhase { get; set; }
	private float DisplaySecondsRemaining { get; set; }

	protected override void OnUpdate()
	{
		base.OnUpdate();
	}

	private void UpdateHudText()
	{
		var roundManager = FloodGameManager.Instance;

		if ( !roundManager.IsValid() )
		{
			SetHudState( false, "No Round", "--:--" );
			return;
		}

		var phase = roundManager.CurrentPhase;
		var shouldShow = ShowDuringWaiting || phase != GamePhase.WaitingForPlayers;
		var syncedSeconds = roundManager.GetCurrentPhaseTimeRemaining();

		var phaseText = GetPhaseText( phase );
		var displaySeconds = GetDisplaySecondsRemaining( roundManager, phase, syncedSeconds );
		var timeText = GetTimeText( displaySeconds );

		if ( ShowDebugValues )
			timeText = $"{timeText} | raw:{syncedSeconds:0.0}";

		SetHudState( shouldShow, phaseText, timeText );
	}

	private float GetDisplaySecondsRemaining( FloodGameManager roundManager, GamePhase phase, float syncedSeconds )
	{
		syncedSeconds = syncedSeconds.Clamp( 0f, float.MaxValue );

		if ( LastDisplayedPhase != phase )
		{
			LastDisplayedPhase = phase;
			DisplaySecondsRemaining = syncedSeconds > 0f
				? syncedSeconds
				: roundManager.GetCurrentPhaseDuration();

			return DisplaySecondsRemaining;
		}

		if ( syncedSeconds > DisplaySecondsRemaining || MathF.Abs( syncedSeconds - DisplaySecondsRemaining ) > 1.25f )
		{
			DisplaySecondsRemaining = syncedSeconds;
			return DisplaySecondsRemaining;
		}

		DisplaySecondsRemaining -= Time.Delta;
		DisplaySecondsRemaining = DisplaySecondsRemaining.Clamp( 0f, float.MaxValue );

		return DisplaySecondsRemaining;
	}

	private string GetPhaseText( GamePhase phase )
	{
		return phase switch
		{
			GamePhase.WaitingForPlayers => "Waiting",
			GamePhase.BuildPhase => "Build Phase",
			GamePhase.FloodPhase => "Flood Phase",
			GamePhase.CombatPhase => "Combat Phase",
			GamePhase.RoundEnd => "Round End",
			_ => phase.ToString()
		};
	}

	private string GetTimeText( float seconds )
	{
		seconds = seconds.Clamp( 0f, float.MaxValue );

		var totalSeconds = MathF.Ceiling( seconds );
		var minutes = (int)(totalSeconds / 60f);
		var remainingSeconds = (int)(totalSeconds % 60f);

		return $"{minutes:00}:{remainingSeconds:00}";
	}

	private void SetHudState( bool shouldShow, string phaseText, string timeText )
	{
		if (
			ShouldShow == shouldShow &&
			PhaseText == phaseText &&
			TimeText == timeText
		)
		{
			return;
		}

		ShouldShow = shouldShow;
		PhaseText = phaseText;
		TimeText = timeText;

		HudBuildVersion++;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			HudBuildVersion,
			ShouldShow,
			PhaseText,
			TimeText,
			ShowDuringWaiting,
			ShowDebugValues
		);
	}
}
