@using Sandbox

@inherits PanelComponent

<root>
	@if ( ShouldShowHud )
	{
		<div class="build-hud">
			<div class="build-hud__title">Build Mode</div>

			<div class="build-hud__row">
				<span>Tool</span>
				<strong>@ActiveToolName</strong>
			</div>

			<div class="build-hud__row">
				<span>Resources</span>
				<strong>@ResourceText</strong>
			</div>

			<div class="build-hud__hint">
				LMB: Place &nbsp; RMB: Next Piece &nbsp; R: Rotate
			</div>
		</div>
	}
</root>

@code
{
	private FloodPlayer Player => FloodPlayer.Local;

	private PlayerInventory Inventory => Player?.Inventory;
	private PlayerBuildResources BuildResources => Player?.BuildResources;

	private BoatBuilder BoatBuilder => Inventory?.ActiveCarryable as BoatBuilder;

	private bool ShouldShowHud
	{
		get
		{
			if ( !Player.IsValid() )
				return false;

			if ( !Inventory.IsValid() )
				return false;

			return BoatBuilder.IsValid();
		}
	}

	private string ActiveToolName
	{
		get
		{
			if ( !Inventory.IsValid() )
				return "None";

			return Inventory.ActiveCarryableName;
		}
	}

	private string ResourceText
	{
		get
		{
			if ( !BuildResources.IsValid() )
				return "--";

			return BuildResources.Resources.ToString();
		}
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			ShouldShowHud,
			ActiveToolName,
			ResourceText
		);
	}
}
