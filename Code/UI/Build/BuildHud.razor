@using Sandbox
@using System

@inherits PanelComponent

<root>
	@if ( ShouldShowHud )
	{
		<div class="build-hud">
			<div class="build-hud__title">Build Mode</div>

			<div class="build-hud__row">
				<span>Tool</span>
				<strong>@ActiveToolName</strong>
			</div>

			<div class="build-hud__row">
				<span>Piece</span>
				<strong>@SelectedPieceName</strong>
			</div>

			<div class="build-hud__row">
				<span>Resources</span>
				<strong>@ResourceText</strong>
			</div>

			<div class="build-hud__hint">
				LMB: Place &nbsp; RMB: Next Piece &nbsp; R: Rotate
			</div>
		</div>
	}
</root>

@code
{
	private FloodPlayer Player => FloodPlayer.Local;

	private PlayerInventory Inventory
	{
		get
		{
			if ( !Player.IsValid() )
				return null;

			return Player.Inventory;
		}
	}

	private PlayerBuildResources BuildResources
	{
		get
		{
			if ( !Player.IsValid() )
				return null;

			return Player.BuildResources;
		}
	}

	private BaseCarryable ActiveCarryable
	{
		get
		{
			if ( !Inventory.IsValid() )
				return null;

			return Inventory.ActiveCarryable;
		}
	}

	private BoatBuilder BoatBuilder
	{
		get
		{
			if ( !ActiveCarryable.IsValid() )
				return null;

			return ActiveCarryable as BoatBuilder;
		}
	}

	private bool ShouldShowHud
	{
		get
		{
			if ( !Player.IsValid() )
				return false;

			if ( !Inventory.IsValid() )
				return false;

			// Show while the Boat Builder is active.
			return BoatBuilder.IsValid();
		}
	}

	private string ActiveToolName
	{
		get
		{
			if ( !ActiveCarryable.IsValid() )
				return "None";

			return ActiveCarryable.DisplayName;
		}
	}

	private string SelectedPieceName
	{
		get
		{
			if ( !BoatBuilder.IsValid() )
				return "None";

			if ( BoatBuilder.SelectedPiece is null )
				return "None";

			return BoatBuilder.SelectedPiece.DisplayName;
		}
	}

	private string ResourceText
	{
		get
		{
			if ( !BuildResources.IsValid() )
				return "--";

			return BuildResources.Resources.ToString();
		}
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			ShouldShowHud,
			ActiveToolName,
			SelectedPieceName,
			ResourceText
		);
	}
}
