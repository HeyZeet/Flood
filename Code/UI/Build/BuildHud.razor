@using Sandbox
@using System

@inherits PanelComponent

<root>
</root>

@code
{
	private string ToolName { get; set; } = "None";
	private string PieceName { get; set; } = "None";
	private string ResourceText { get; set; } = "--";
	private string HintText { get; set; } = "";

	private bool ShouldShowHud { get; set; }

	private int HudBuildVersion { get; set; }

	protected override void OnUpdate()
	{
		base.OnUpdate();
	}

	private void UpdateHudText()
	{
		var player = FloodPlayer.Local;

		if ( !player.IsValid() )
		{
			SetHudState( false, "No Player", "None", "--", "" );
			return;
		}

		if ( player.IsDead )
		{
			SetHudState( false, "Dead", "None", "--", "" );
			return;
		}

		var roundManager = FloodGameManager.Instance;

		if ( roundManager.IsValid() && !roundManager.IsBuildPhase() )
		{
			SetHudState( false, "Not Build Phase", "None", "--", "" );
			return;
		}

		var inventory = player.Inventory;

		if ( !inventory.IsValid() )
		{
			SetHudState( false, "No Inventory", "None", "--", "" );
			return;
		}

		var activeCarryable = inventory.ActiveCarryable;

		if ( !activeCarryable.IsValid() )
		{
			SetHudState( false, "None", "None", "--", "" );
			return;
		}

		var resources = player.BuildResources;
		var resourceText = resources.IsValid() ? resources.Resources.ToString() : "--";

		if ( activeCarryable is BoatBuilder boatBuilder )
		{
			var toolName = boatBuilder.DisplayName;
			var pieceName = boatBuilder.SelectedPiece?.DisplayName ?? "None";

			SetHudState( true, toolName, pieceName, resourceText, "LMB: Place   RMB: Next Piece   R: Rotate" );
			return;
		}

		var weldTool = activeCarryable.Components.Get<WeldToolWeapon>( FindMode.EverythingInSelfAndDescendants );

		if ( weldTool.IsValid() )
		{
			SetHudState( true, weldTool.DisplayName, weldTool.FirstWeldTargetName, resourceText, "LMB: Select/Weld   RMB: Unweld" );
			return;
		}

		SetHudState( false, "None", "None", "--", "" );
	}

	private void SetHudState( bool shouldShow, string toolName, string pieceName, string resourceText, string hintText )
	{
		if (
			ShouldShowHud == shouldShow &&
			ToolName == toolName &&
			PieceName == pieceName &&
			ResourceText == resourceText &&
			HintText == hintText
		)
		{
			return;
		}

		ShouldShowHud = shouldShow;
		ToolName = toolName;
		PieceName = pieceName;
		ResourceText = resourceText;
		HintText = hintText;

		HudBuildVersion++;
	}

	protected override int BuildHash()
	{
		return HashCode.Combine(
			HudBuildVersion,
			ShouldShowHud,
			ToolName,
			PieceName,
			ResourceText,
			HintText
		);
	}
}
